# ── AEGIBIT environment variables ────────────────────────────────────
# Copy this file to .env.local and fill in real values for local dev.
# In production, set the same keys in Vercel → Project → Settings →
# Environment Variables. Never commit .env.local — it is gitignored.

# Supabase (server-side reads, lead writes)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Postgres direct URL (Prisma migrations, debugging)
DATABASE_URL=

# Resend transactional email
RESEND_API_KEY=
# Comma-separated list — every founder inbox that should receive lead alerts
TEAM_NOTIFY_EMAILS=contact@aegibit.com

# Public app URL (used by sitemap + canonical metadata)
NEXT_PUBLIC_APP_URL=https://www.aegibit.com
NEXT_PUBLIC_APP_NAME=AEGIBIT

# ── Admin auth (httpOnly cookie session) ─────────────────────────────
# Generate SESSION_SECRET with: openssl rand -base64 48
SESSION_SECRET=

# Generate ADMIN_PASSWORD_HASH with: node scripts/hash-password.mjs
# (paste only the hash, never the plaintext password)
ADMIN_PASSWORD_HASH=

# ── Server-to-server agent API (deploy-notify, etc.) ────────────────
# Used by Aira automation for /api/admin/deploy-notify. Different from
# the admin password — agents authenticate with this bearer token.
# Generate with: openssl rand -base64 32
DASHBOARD_SECRET=

# ── Upstash Redis (rate limiting) ────────────────────────────────────
# OPTIONAL but strongly recommended. Without these, the rate limiter
# falls back to in-memory which DOES NOT work correctly across parallel
# Vercel lambdas. Sign up free at https://console.upstash.com,
# create a Redis database, and copy the REST URL + token here.
# Free tier: 10K commands/day, 256 MB — enough for early traffic.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Slack hot-lead push (P3-S5) ──────────────────────────────────────
# OPTIONAL. When set, /api/leads pushes a Block Kit message to your
# Slack channel on every form submit. Hot leads get a red-bordered
# urgency message with full visitor journey embedded; warm leads get
# a one-line notice. Free.
# Setup: api.slack.com/apps → Create app → Incoming Webhooks → ON →
# Add new webhook to workspace → pick channel → copy URL.
SLACK_HOT_LEAD_WEBHOOK_URL=

# ── Aira chatbot (P3-S10, Gemini Flash backbone) ────────────────────
# OPTIONAL but STRONGLY recommended — without this, the chat widget
# gracefully degrades to "let me connect you with a founder" on every
# message (still captures leads, just no actual conversation).
# Free tier: 1500 requests/day, 1M tokens/min — hard-capped, no
# surprise bills.
# Setup: https://aistudio.google.com → "Get API key" → "Create API
# key in new project" → copy. No credit card required.
GEMINI_API_KEY=
